pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Repositorio clonado correctamente'
            }
        }

        stage('Build') {
            steps {
                echo 'Proceso de build ejecutado'
            }
        }

        stage('Test') {
            steps {
                echo 'Pipeline CI funcionando correctamente'
            }
        }
    }
}
